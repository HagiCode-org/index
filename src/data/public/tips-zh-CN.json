  "tips": [
    {
      "id": "project-first",
      "text": "先创建项目，再开启会话，方便 HagiCode 统一管理文件、上下文和历史记录。",
      "category": "project"
    },
    {
      "id": "project-boundary",
      "text": "一个项目只放相关代码和资料，避免会话读取到无关上下文。",
      "category": "project"
    },
    {
      "id": "project-name-clear",
      "text": "项目名称尽量使用业务或仓库名，后续查找会更直观。",
      "category": "project"
    },
    {
      "id": "project-goal-note",
      "text": "在项目里记录当前目标，后续会话能更快接上。",
      "category": "project"
    },
    {
      "id": "project-docs",
      "text": "把启动方式、账号信息和常用命令放进项目说明，减少重复解释。",
      "category": "project"
    },
    {
      "id": "project-context-clean",
      "text": "上传资料前先删掉无关文件，能让 HagiCode 更专注当前任务。",
      "category": "project"
    },
    {
      "id": "project-before-session",
      "text": "开新会话前先选对项目，避免把任务放进错误上下文。",
      "category": "project"
    },
    {
      "id": "project-history",
