---
import { getLocaleNamespace, getString } from '@/i18n/runtime';

const copy = getLocaleNamespace('hagindex');
const footerLinks = {
  portal: [
    { id: 'home', href: '/', code: '/' },
    { id: 'data', href: '/data/', code: '/data/' },
    { id: 'promoto', href: '/promoto', code: '/promoto' },
  ],
  json: [
    { id: 'sites', href: '/sites.json', code: '/sites.json' },
    { id: 'catalog', href: '/index-catalog.json', code: '/index-catalog.json' },
    { id: 'about', href: '/about.json', code: '/about.json' },
    { id: 'design', href: '/design.json', code: '/design.json' },
  ],
  history: [
    { id: 'desktopHistory', href: '/desktop/history/', code: '/desktop/history/' },
    { id: 'serverHistory', href: '/server/history/', code: '/server/history/' },
    { id: 'promote', href: '/promote.json', code: '/promote.json' },
    { id: 'promoteContent', href: '/promote_content.json', code: '/promote_content.json' },
  ],
} as const;

const columns = [
  { id: 'portal', links: footerLinks.portal },
  { id: 'json', links: footerLinks.json },
  { id: 'history', links: footerLinks.history },
] as const;
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-intro">
      <p class="eyebrow">{getString(copy, 'footer.eyebrow')}</p>
      <h2>{getString(copy, 'footer.title')}</h2>
    </div>

    {columns.map((column) => (
      <div class="footer-column">
        <p class="footer-column-title">{getString(copy, `footer.columns.${column.id}`)}</p>
        <nav class="footer-link-list" aria-label={getString(copy, `footer.aria.${column.id}`)}>
          {column.links.map((link) => (
            <a class="footer-link" href={link.href}>
              <span>{getString(copy, `footer.links.${link.id}`)}</span>
              <code>{link.code}</code>
            </a>
          ))}
        </nav>
      </div>
    ))}
  </div>
</footer>
