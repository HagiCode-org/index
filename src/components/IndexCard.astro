---
import type { IndexCatalogEntry } from '@/lib/load-index-catalog';

interface Props {
  entry: IndexCatalogEntry;
}

const { entry } = Astro.props;
const updatedLabel = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'long',
  timeZone: 'UTC',
}).format(new Date(entry.lastUpdated));
const copyUrl = new URL(entry.path, 'https://index.hagicode.com').toString();
const statusLabel = entry.status === 'published' ? '已发布' : entry.status;
---

<article class="index-card">
  <div class="card-topline">
    <p class="card-category">{entry.category}</p>
    <span class="status-badge">{statusLabel}</span>
  </div>

  <div class="card-heading">
    <h2>{entry.title}</h2>
  </div>

  <div class="card-chip-row" aria-label={`${entry.title} 关键信息`}>
    <span class="info-chip">{entry.sourceRepo}</span>
    <span class="info-chip">
      <code>{entry.path}</code>
    </span>
  </div>

  <dl class="card-meta">
    {entry.historyPagePath ? (
      <div>
        <dt>历史页面</dt>
        <dd><code>{entry.historyPagePath}</code></dd>
      </div>
    ) : null}
    <div>
      <dt>来源仓库</dt>
      <dd>{entry.sourceRepo}</dd>
    </div>
    <div>
      <dt>更新时间</dt>
      <dd>{updatedLabel}</dd>
    </div>
  </dl>

  {entry.activityMetrics ? (
    <section class="activity-summary" aria-label={`${entry.title} 活动摘要`}>
      <p class="activity-summary-title">活动摘要</p>
      <dl class="activity-summary-grid">
        <div class="activity-summary-item">
          <dt>活跃用户</dt>
          <dd>{entry.activityMetrics.activeUsers}</dd>
        </div>
        <div class="activity-summary-item">
          <dt>活跃会话</dt>
          <dd>{entry.activityMetrics.activeSessions}</dd>
        </div>
        <div class="activity-summary-item">
          <dt>时间窗口</dt>
          <dd>{entry.activityMetrics.dateRange}</dd>
        </div>
      </dl>
    </section>
  ) : null}

  <div class="card-actions" aria-label={`${entry.title} 操作`}>
    <a class="button button-primary" href={entry.path} target="_blank" rel="noreferrer">
      原始 JSON
    </a>

    {entry.historyPagePath ? (
      <a class="button button-secondary" href={entry.historyPagePath}>
        版本历史
      </a>
    ) : null}

    {entry.readmePath ? (
      <a class="button button-secondary" href={entry.readmePath} target="_blank" rel="noreferrer">
        查看 README
      </a>
    ) : null}

    <button
      class="button button-tertiary"
      type="button"
      data-copy-url={copyUrl}
      aria-label={`复制 ${entry.title} 的原始 JSON 链接`}
    >
      复制链接
    </button>
  </div>

  {entry.sourceUrl ? (
    <p class="card-source-link">
      <a href={entry.sourceUrl} target="_blank" rel="noreferrer">
        查看源目录 →
      </a>
    </p>
  ) : null}
</article>
