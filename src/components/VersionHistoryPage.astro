---
import type { PackageHistoryPageModel, VersionHistoryFileEntry } from '@/lib/load-package-history';

interface Props {
  page: PackageHistoryPageModel;
}

const { page } = Astro.props;
const totalReleases = page.releases.length;
const latestRelease = page.latestRelease;
const updatedSummary = page.generatedAt ? page.generatedAtLabel : '未知';
const historyKicker = page.source === 'server' ? '按版本分组的 ZIP 下载记录' : '按版本分组的完整发布记录';
const sourceKindLabels: Record<VersionHistoryFileEntry['sourceKind'], string> = {
  release: 'release',
  assets: 'assets',
  downloads: 'downloads',
  artifacts: 'artifacts',
  files: 'files',
};

function formatFileMeta(file: VersionHistoryFileEntry): string {
  const parts = [sourceKindLabels[file.sourceKind]];

  if (file.sizeLabel) {
    parts.push(file.sizeLabel);
  } else {
    parts.push('大小未知');
  }

  parts.push(file.publishedAt ? file.publishedLabel : '时间未知');
  return parts.join(' · ');
}

function getPrimaryFileActionLabel(file: VersionHistoryFileEntry): string {
  if (file.sources.length === 1) {
    return file.sources[0].label;
  }

  return '下载';
}
---

<section class="history-shell">
  <section class="hero-panel history-panel" aria-labelledby="history-heading">
    <div class="history-hero-grid">
      <div class="history-copy">
        <p class="eyebrow">{page.sourceLabel} history</p>
        <div>
          <p class="hero-kicker">{historyKicker}</p>
          <h1 id="history-heading">{page.title}</h1>
        </div>
        <div class="hero-actions">
          <a class="button button-secondary" href="/">
            返回首页
          </a>
          <a class="button button-primary" href={page.sourceJsonPath} target="_blank" rel="noreferrer">
            原始 JSON
          </a>
        </div>
      </div>

      <div class="history-summary-grid" aria-label={`${page.sourceLabel} 历史摘要`}>
        <article class="history-summary-card">
          <p class="history-summary-label">版本总数</p>
          <p class="history-summary-value">{totalReleases}</p>
        </article>
        <article class="history-summary-card">
          <p class="history-summary-label">最新发布</p>
          <p class="history-summary-value history-summary-text">
            {latestRelease ? latestRelease.version : '暂无发布'}
          </p>
          <p class="history-summary-note">
            {latestRelease ? `${latestRelease.publishedLabel} · ${latestRelease.fileCount} 个文件` : '暂无记录'}
          </p>
        </article>
        <article class="history-summary-card">
          <p class="history-summary-label">数据来源</p>
          <p class="history-summary-value history-summary-text">
            <code>{page.sourceJsonPath}</code>
          </p>
          <p class="history-summary-note">{updatedSummary}</p>
        </article>
      </div>
    </div>

    {latestRelease ? (
      <article class="history-latest-card" aria-label="最新发布摘要">
        <div>
          <p class="card-category">Latest grouped release</p>
          <h2>{latestRelease.version}</h2>
        </div>
        <dl class="history-latest-meta">
          <div>
            <dt>发布日期</dt>
            <dd>{latestRelease.publishedLabel}</dd>
          </div>
          <div>
            <dt>文件数</dt>
            <dd>{latestRelease.fileCount}</dd>
          </div>
          <div>
            <dt>可下载文件</dt>
            <dd>{latestRelease.downloadableFileCount}</dd>
          </div>
          <div>
            <dt>首个文件</dt>
            <dd>{latestRelease.primaryArtifactLabel}</dd>
          </div>
        </dl>
        <div class="history-row-actions" aria-label={`${latestRelease.version} 操作`}>
          {latestRelease.actions.map((action) => (
            <a
              class={`button ${action.kind === 'download' ? 'button-primary' : 'button-secondary'}`}
              href={action.href}
              target="_blank"
              rel="noreferrer"
            >
              {action.label}
            </a>
          ))}
        </div>
      </article>
    ) : null}
  </section>

  <section class="catalog-section history-release-section" aria-labelledby="history-release-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Release ledger</p>
        <h2 id="history-release-heading">历史版本</h2>
      </div>
    </div>

    {totalReleases > 0 ? (
      <div class="history-release-list">
        {page.releases.map((release) => (
          <article class="history-release-card" aria-labelledby={`release-${release.version}`}>
            <div class="history-release-head">
              <div class="history-release-copy">
                <p class="card-category">{page.sourceLabel} release group</p>
                <h3 id={`release-${release.version}`} class="history-release-title">
                  {release.version}
                </h3>
                <p class="history-release-summary">
                  {release.publishedLabel} · {release.fileCount} 个{page.source === 'server' ? ' ZIP 包' : '文件'} · {release.downloadableFileCount} 个可下载
                </p>
              </div>
              <div class="history-release-actions" aria-label={`${release.version} 分组操作`}>
                {release.actions.map((action) => (
                  <a
                    class={`button ${action.kind === 'download' ? 'button-tertiary' : 'button-secondary'}`}
                    href={action.href}
                    target="_blank"
                    rel="noreferrer"
                  >
                    {action.label}
                  </a>
                ))}
              </div>
            </div>

            {release.fileCount > 0 ? (
              <ul class="history-file-list">
                {release.files.map((file) => (
                  <li class="history-file-item">
                    <div class="history-file-copy">
                      <p class="history-file-name">{file.label}</p>
                      <p class="history-file-meta">{formatFileMeta(file)}</p>
                      {file.sources.length > 1 ? (
                        <p class="history-file-source-note">多下载源</p>
                      ) : null}
                    </div>
                    {file.sources.length > 0 ? (
                      <div class="history-row-actions history-file-actions" aria-label={`${file.label} 下载来源`}>
                        {file.sources.map((source, index) => (
                          <a
                            class={`button ${index === 0 ? 'button-primary' : 'button-secondary'} history-file-action`}
                            href={source.href}
                            target="_blank"
                            rel="noreferrer"
                          >
                            {source.label}
                          </a>
                        ))}
                      </div>
                    ) : file.href ? (
                      <a class="button button-primary history-file-action" href={file.href} target="_blank" rel="noreferrer">
                        {getPrimaryFileActionLabel(file)}
                      </a>
                    ) : (
                      <span class="button button-disabled history-file-action" aria-disabled="true">
                        仅索引可见
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            ) : (
              <div class="history-release-empty" role="status">
                <p>当前版本无文件清单。</p>
              </div>
            )}
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state history-empty-state" role="status" aria-live="polite">
        <p>当前还没有已发布版本。</p>
      </div>
    )}
  </section>
</section>
