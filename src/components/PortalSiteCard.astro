---
import type { SitesCatalogEntry } from '@/lib/load-sites-catalog';
import { formatI18n, getLocaleNamespace, getString } from '@/i18n/runtime';

interface Props {
  entry: SitesCatalogEntry;
}

const { entry } = Astro.props;
const hostLabel = new URL(entry.url).hostname;
const copy = getLocaleNamespace('hagindex');
---

<article class="portal-site-card">
  <div class="portal-site-topline">
    <p class="card-category">{entry.label}</p>
    <span class="status-badge">{getString(copy, 'siteCard.productionBadge')}</span>
  </div>

  <div class="portal-site-copy">
    <h3>{entry.title}</h3>
  </div>

  <p class="portal-site-domain">
    <code>{hostLabel}</code>
  </p>

  <div class="card-actions" aria-label={formatI18n(getString(copy, 'siteCard.actionAriaTemplate'), { title: entry.title })}>
    <a class="button button-primary" href={entry.url} target="_blank" rel="noreferrer">
      {entry.actionLabel}
    </a>
  </div>
</article>
