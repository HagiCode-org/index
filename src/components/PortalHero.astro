---
import type { SitesCatalogEntry } from '@/lib/load-sites-catalog';
import { getLocaleNamespace, getString } from '@/i18n/runtime';

interface Props {
  siteCount: number;
  groupCount: number;
  publicIndexCount: number;
  routeCount: number;
  generatedAtLabel: string;
  featuredEntries: SitesCatalogEntry[];
  dataPagePath: string;
  sitesJsonPath: string;
  catalogPath: string;
}

const {
  siteCount,
  groupCount,
  publicIndexCount,
  routeCount,
  generatedAtLabel,
  featuredEntries,
  dataPagePath,
  sitesJsonPath,
  catalogPath,
} = Astro.props;
const copy = getLocaleNamespace('hagindex');
---

<section class="hero-panel portal-hero" aria-labelledby="portal-hero-heading">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{getString(copy, 'hero.eyebrow')}</p>
      <div>
        <p class="hero-kicker">{getString(copy, 'hero.kicker')}</p>
        <h1 id="portal-hero-heading">{getString(copy, 'hero.title')}</h1>
      </div>

      <div class="hero-actions">
        {featuredEntries.map((entry) => (
          <a class="button button-primary" href={entry.url} target="_blank" rel="noreferrer">
            {entry.actionLabel}
          </a>
        ))}
        <a class="button button-secondary" href={dataPagePath}>
          {getString(copy, 'hero.actions.dataMirror')}
        </a>
        <a class="button button-tertiary" href={sitesJsonPath} target="_blank" rel="noreferrer">
          {getString(copy, 'hero.actions.sitesJson')}
        </a>
      </div>

      <div class="hero-route-strip" aria-label={getString(copy, 'hero.routesAria')}>
        <a class="hero-route-chip" href={catalogPath} target="_blank" rel="noreferrer">
          <span>{getString(copy, 'hero.routes.catalog')}</span>
          <code>/index-catalog.json</code>
        </a>
        <a class="hero-route-chip" href="/desktop/history/">
          <span>{getString(copy, 'hero.routes.desktopHistory')}</span>
          <code>/desktop/history/</code>
        </a>
        <a class="hero-route-chip" href="/server/history/">
          <span>{getString(copy, 'hero.routes.serverHistory')}</span>
          <code>/server/history/</code>
        </a>
        <a class="hero-route-chip" href="/promoto">
          <span>{getString(copy, 'hero.routes.promoto')}</span>
          <code>/promoto</code>
        </a>
      </div>
    </div>

    <div class="hero-aside">
      <dl class="hero-metrics" aria-label={getString(copy, 'hero.metricsAria')}>
        <div>
          <dt>{getString(copy, 'hero.metrics.siteCount')}</dt>
          <dd>{siteCount}</dd>
        </div>
        <div>
          <dt>{getString(copy, 'hero.metrics.groupCount')}</dt>
          <dd>{groupCount}</dd>
        </div>
        <div>
          <dt>{getString(copy, 'hero.metrics.publicIndexCount')}</dt>
          <dd>{publicIndexCount}</dd>
        </div>
        <div>
          <dt>{getString(copy, 'hero.metrics.routeCount')}</dt>
          <dd>{routeCount}</dd>
        </div>
      </dl>

      <article class="hero-signal-card">
        <p class="card-category">{getString(copy, 'hero.signal.category')}</p>
        <h2>{getString(copy, 'hero.signal.title')}</h2>
        <div class="hero-signal-meta">
          <div>
            <p class="signal-label">{getString(copy, 'hero.signal.deliveryLabel')}</p>
            <p class="signal-value">{getString(copy, 'hero.signal.deliveryValue')}</p>
          </div>
          <div>
            <p class="signal-label">{getString(copy, 'hero.signal.snapshotLabel')}</p>
            <p class="signal-value">{generatedAtLabel}</p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
