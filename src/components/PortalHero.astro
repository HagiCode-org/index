---
import type { SitesCatalogEntry } from '@/lib/load-sites-catalog';

interface Props {
  siteCount: number;
  groupCount: number;
  publicIndexCount: number;
  routeCount: number;
  generatedAtLabel: string;
  featuredEntries: SitesCatalogEntry[];
  dataPagePath: string;
  sitesJsonPath: string;
  catalogPath: string;
}

const {
  siteCount,
  groupCount,
  publicIndexCount,
  routeCount,
  generatedAtLabel,
  featuredEntries,
  dataPagePath,
  sitesJsonPath,
  catalogPath,
} = Astro.props;
---

<section class="hero-panel portal-hero" aria-labelledby="portal-hero-heading">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">index.hagicode.com</p>
      <div>
        <p class="hero-kicker">Site switchboard</p>
        <h1 id="portal-hero-heading">HagiCode Index 站群总控台</h1>
      </div>

      <div class="hero-actions">
        {featuredEntries.map((entry) => (
          <a class="button button-primary" href={entry.url} target="_blank" rel="noreferrer">
            {entry.actionLabel}
          </a>
        ))}
        <a class="button button-secondary" href={dataPagePath}>
          打开数据镜像
        </a>
        <a class="button button-tertiary" href={sitesJsonPath} target="_blank" rel="noreferrer">
          站点清单 JSON
        </a>
      </div>

      <div class="hero-route-strip" aria-label="首页重点出口">
        <a class="hero-route-chip" href={catalogPath} target="_blank" rel="noreferrer">
          <span>目录索引</span>
          <code>/index-catalog.json</code>
        </a>
        <a class="hero-route-chip" href="/desktop/history/">
          <span>Desktop 历史页</span>
          <code>/desktop/history/</code>
        </a>
        <a class="hero-route-chip" href="/server/history/">
          <span>Server 历史页</span>
          <code>/server/history/</code>
        </a>
        <a class="hero-route-chip" href="/promoto">
          <span>Promoto 展示台</span>
          <code>/promoto</code>
        </a>
      </div>
    </div>

    <div class="hero-aside">
      <dl class="hero-metrics" aria-label="门户概览">
        <div>
          <dt>站点入口</dt>
          <dd>{siteCount}</dd>
        </div>
        <div>
          <dt>站群分组</dt>
          <dd>{groupCount}</dd>
        </div>
        <div>
          <dt>公开索引</dt>
          <dd>{publicIndexCount}</dd>
        </div>
        <div>
          <dt>稳定路由</dt>
          <dd>{routeCount}</dd>
        </div>
      </dl>

      <article class="hero-signal-card">
        <p class="card-category">Operational signal</p>
        <h2>入口 / JSON / 历史</h2>
        <div class="hero-signal-meta">
          <div>
            <p class="signal-label">交付方式</p>
            <p class="signal-value">静态发布</p>
          </div>
          <div>
            <p class="signal-label">站点快照</p>
            <p class="signal-value">{generatedAtLabel}</p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
