---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import AboutSection from '@/components/AboutSection.astro';
import IndexCard from '@/components/IndexCard.astro';
import IndexFooter from '@/components/IndexFooter.astro';
import IndexHero from '@/components/IndexHero.astro';
import { loadAboutPayload } from '@/lib/load-about';
import { loadIndexCatalog } from '@/lib/load-index-catalog';
import '@/styles/global.css';

const catalog = await loadIndexCatalog();
const about = loadAboutPayload();
const publishedEntries = catalog.entries.filter((entry) => entry.status === 'published').length;
const categoryCount = new Set(catalog.entries.map((entry) => entry.category)).size;
const generatedAtLabel = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
}).format(new Date(catalog.generatedAt));
const pageTitle = 'HagiCode Index Data';
const pageDescription = 'HagiCode Index 的数据镜像页，集中展示 catalog、about、awesome-design-md 主题目录与公开 JSON 入口。';
const canonicalUrl = 'https://index.hagicode.com/data/';
const firstPublishedPath = catalog.entries.find((entry) => entry.status === 'published')?.path ?? null;
const dataSurfaces = [
  {
    title: '索引目录',
    href: '/index-catalog.json',
    label: 'catalog',
    actionLabel: '打开 catalog JSON',
  },
  {
    title: '联系与社区',
    href: '/about.json',
    label: 'about',
    actionLabel: '打开 about JSON',
  },
  {
    title: '设计目录',
    href: '/design.json',
    label: 'design',
    actionLabel: '打开 design JSON',
  },
  {
    title: '推广内容',
    href: '/promote_content.json',
    label: 'promotion',
    actionLabel: '打开 promotion JSON',
  },
  {
    title: 'Steam 成就页面',
    href: '/steam/achievements/',
    label: 'steam page',
    actionLabel: '打开 Steam 成就页面',
  },
  {
    title: 'Steam 成就 JSON',
    href: '/steam/achievements.json',
    label: 'steam raw',
    actionLabel: '打开 Steam 成就 JSON',
  },
] as const;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand-mark" href="/">H</a>
        <div>
          <p class="brand-name">HagiCode Index Data</p>
          <p class="brand-subtitle">Legacy data mirror and JSON inspection page</p>
        </div>
        <nav class="site-header-actions" aria-label="数据页快捷入口">
          <a class="header-link" href="/">返回站点门户</a>
          <a class="header-link" href="/sites.json" target="_blank" rel="noreferrer">站点 JSON</a>
          <a class="header-link" href="/index-catalog.json" target="_blank" rel="noreferrer">目录 JSON</a>
        </nav>
      </header>

      <main class="page-content">
        <IndexHero
          totalCount={catalog.entries.length}
          publishedCount={publishedEntries}
          categoryCount={categoryCount}
          generatedAtLabel={generatedAtLabel}
          catalogPath="/index-catalog.json"
          primaryPath={firstPublishedPath}
          portalPath="/"
          aboutPath="/about.json"
          designPath="/design.json"
        />

        <section class="catalog-section data-surface-section" aria-labelledby="data-surface-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Mirror lanes</p>
              <h2 id="data-surface-heading">数据镜像把原始 JSON 和可读页面一起公开</h2>
            </div>
          </div>

          <div class="portal-surface-grid">
            {dataSurfaces.map((surface) => (
              <article class="portal-surface-card">
                <div class="portal-site-topline">
                  <p class="card-category">{surface.label}</p>
                  <span class="status-badge">public json</span>
                </div>
                <div class="portal-site-copy">
                  <h3>{surface.title}</h3>
                </div>
                <div class="card-actions">
                  <a class="button button-secondary" href={surface.href} target="_blank" rel="noreferrer">
                    {surface.actionLabel}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="catalog-section" aria-labelledby="catalog-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Catalog</p>
              <h2 id="catalog-heading">索引目录</h2>
            </div>
          </div>

          {catalog.entries.length > 0 ? (
            <div class="card-grid">
              {catalog.entries.map((entry) => (
                <IndexCard entry={entry} />
              ))}
            </div>
          ) : (
            <div class="empty-state" role="status" aria-live="polite">
              <p>当前还没有已发布索引。</p>
            </div>
          )}
        </section>

        <AboutSection about={about} />
      </main>

      <IndexFooter />
      <p class="sr-only" id="copy-status" aria-live="polite"></p>
    </div>

    <script is:inline>
      const statusNode = document.getElementById('copy-status');
      const buttons = document.querySelectorAll('[data-copy-url]');

      const setStatus = (message) => {
        if (statusNode) {
          statusNode.textContent = message;
        }
      };

      for (const button of buttons) {
        button.addEventListener('click', async () => {
          const url = button.getAttribute('data-copy-url');
          if (!url) {
            return;
          }

          try {
            await navigator.clipboard.writeText(url);
            setStatus(`已复制链接：${url}`);
            const previousLabel = button.textContent;
            button.textContent = '已复制';
            window.setTimeout(() => {
              button.textContent = previousLabel;
            }, 1600);
          } catch {
            setStatus('复制失败，请手动复制原始 JSON 链接。');
          }
        });
      }
    </script>
    <Analytics51LA />
  </body>
</html>
