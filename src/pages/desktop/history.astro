---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import IndexFooter from '@/components/IndexFooter.astro';
import VersionHistoryPage from '@/components/VersionHistoryPage.astro';
import { loadPackageHistory } from '@/lib/load-package-history';
import '@/styles/global.css';

const page = await loadPackageHistory('desktop');
const pageTitle = `${page.title} | HagiCode Index`;
const pageDescription = 'HagiCode Desktop 的按版本分组历史页，完整展示 /desktop/index.json 中每个版本的全部已知文件。';
const canonicalUrl = 'https://index.hagicode.com/desktop/history/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand-mark" href="/">H</a>
        <div>
          <p class="brand-name">HagiCode Index</p>
          <p class="brand-subtitle">Desktop grouped package history</p>
        </div>
        <nav class="site-header-actions" aria-label="Desktop 历史页快捷入口">
          <a class="header-link" href="/">门户</a>
          <a class="header-link" href="/data/">数据页</a>
          <a class="header-link" href="/desktop/index.json" target="_blank" rel="noreferrer">Raw JSON</a>
        </nav>
      </header>

      <main class="page-content">
        <VersionHistoryPage page={page} />
      </main>

      <IndexFooter />
    </div>
    <Analytics51LA />
  </body>
</html>
