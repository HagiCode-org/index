---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import IndexFooter from '@/components/IndexFooter.astro';
import PromotoShowcase from '@/components/PromotoShowcase.astro';
import { promoteContentPayload } from '@/data/promote-content-source';
import { getLocaleNamespace, getString } from '@/i18n/runtime';
import '@/styles/global.css';

const copy = getLocaleNamespace('promoto');
const pageTitle = getString(copy, 'metadata.title');
const pageDescription = getString(copy, 'metadata.description');
const canonicalUrl = 'https://index.hagicode.com/promoto';
const rawPayloadPath = '/promote.json';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <div class="page-shell promoto-page-shell">
      <header class="site-header">
        <a class="brand-mark" href="/" aria-label={getString(copy, 'header.brandAria')}>H</a>
        <div>
          <p class="brand-name">{getString(copy, 'header.brandName')}</p>
          <p class="brand-subtitle">{getString(copy, 'header.brandSubtitle')}</p>
        </div>
        <nav class="site-header-actions" aria-label={getString(copy, 'header.navAria')}>
          <a class="header-link" href="/">{getString(copy, 'header.nav.portal')}</a>
          <a class="header-link" href="/data/">{getString(copy, 'header.nav.dataPage')}</a>
          <a class="header-link" href={rawPayloadPath} target="_blank" rel="noreferrer">{getString(copy, 'header.nav.rawJson')}</a>
        </nav>
      </header>

      <main class="page-content">
        <PromotoShowcase
          entries={promoteContentPayload.contents}
          payloadMeta={{ version: promoteContentPayload.version, updatedAt: promoteContentPayload.updatedAt }}
          rawPayloadPath={rawPayloadPath}
        />
      </main>

      <IndexFooter />
    </div>

    <Analytics51LA />
  </body>
</html>
