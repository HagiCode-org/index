---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import IndexFooter from '@/components/IndexFooter.astro';
import PortalHero from '@/components/PortalHero.astro';
import PortalSiteCard from '@/components/PortalSiteCard.astro';
import { loadIndexCatalog } from '@/lib/load-index-catalog';
import { loadSitesCatalog } from '@/lib/load-sites-catalog';
import '@/styles/global.css';

const sitesCatalog = await loadSitesCatalog();
const indexCatalog = await loadIndexCatalog();
const groupedEntries = sitesCatalog.groups.map((group) => ({
  ...group,
  entries: sitesCatalog.entries.filter((entry) => entry.groupId === group.id),
}));
const featuredEntries = sitesCatalog.entries.filter(
  (entry) => entry.id === 'hagicode-main' || entry.id === 'hagicode-docs',
);
const portalGeneratedLabel = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
}).format(new Date(sitesCatalog.generatedAt));
const dataEntryLinks = [
  {
    title: 'Steam 成就页面',
    description: '面向开发者浏览的成就目录、图标预览和稳定公开路径。',
    href: '/steam/achievements/',
  },
  {
    title: '站点导航 JSON',
    description: '供其他站点页脚与工具站同步站群清单。',
    href: '/sites.json',
  },
  {
    title: '目录索引 JSON',
    description: '公开索引目录与状态元数据。',
    href: '/index-catalog.json',
  },
  {
    title: '活动指标 JSON',
    description: '主站运行时消费的首页活动统计数据。',
    href: '/activity-metrics.json',
  },
  {
    title: '直播入口 JSON',
    description: '站内直播入口与公开直播元数据。',
    href: '/live-broadcast.json',
  },
  {
    title: 'Steam 成就 JSON',
    description: 'Steamworks 后台配置用的成就清单、里程碑参数与图标路径。',
    href: '/steam/achievements.json',
  },
  {
    title: '设计目录 JSON',
    description: 'awesome-design-md 的公开目录入口。',
    href: '/design.json',
  },
  {
    title: '法律文档 JSON',
    description: '公开法律文档元数据与落地页映射。',
    href: '/legal-documents.json',
  },
  {
    title: 'Desktop 版本历史',
    description: '可抓取的桌面端历史页与下载入口。',
    href: '/desktop/history/',
  },
  {
    title: 'Server 版本历史',
    description: '可抓取的服务端历史页与索引入口。',
    href: '/server/history/',
  },
];
const operatingSurfaces = [
  {
    title: '门户入口',
    href: '/',
    label: 'portal',
  },
  {
    title: '数据镜像',
    href: '/data/',
    label: 'mirror',
  },
  {
    title: '版本历史',
    href: '/desktop/history/',
    label: 'history',
  },
  {
    title: '运营检查',
    href: '/promoto',
    label: 'review',
  },
] as const;
const routeSignals = [
  {
    title: '站点清单快照',
    value: portalGeneratedLabel,
  },
  {
    title: '公开索引规模',
    value: String(indexCatalog.entries.length),
  },
  {
    title: '稳定入口总数',
    value: String(dataEntryLinks.length),
  },
] as const;
const pageTitle = 'HagiCode Portal';
const pageDescription = 'HagiCode 站点导航门户，集中收纳主站、文档、数据镜像与独立工具站点。';
const canonicalUrl = 'https://index.hagicode.com/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand-mark" href="/">H</a>
        <div>
          <p class="brand-name">HagiCode Portal</p>
          <p class="brand-subtitle">Site navigation and public data handoff</p>
        </div>
        <nav class="site-header-actions" aria-label="门户快捷入口">
          <a class="header-link" href="/data/">数据页</a>
          <a class="header-link" href="/sites.json" target="_blank" rel="noreferrer">站点 JSON</a>
          <a class="header-link" href="/index-catalog.json" target="_blank" rel="noreferrer">查看目录 JSON</a>
        </nav>
      </header>

      <main class="page-content portal-main">
        <PortalHero
          siteCount={sitesCatalog.entries.length}
          groupCount={sitesCatalog.groups.length}
          publicIndexCount={indexCatalog.entries.length}
          routeCount={dataEntryLinks.length}
          generatedAtLabel={portalGeneratedLabel}
          featuredEntries={featuredEntries}
          dataPagePath="/data/"
          sitesJsonPath="/sites.json"
          catalogPath="/index-catalog.json"
        />

        <section class="portal-section portal-surface-section" aria-labelledby="portal-surface-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Control surface</p>
              <h2 id="portal-surface-heading">把 Index 划成四条主线</h2>
            </div>
          </div>

          <div class="portal-surface-grid">
            {operatingSurfaces.map((surface) => (
              <article class="portal-surface-card">
                <div class="portal-site-topline">
                  <p class="card-category">{surface.label}</p>
                  <span class="status-badge">always on</span>
                </div>
                <div class="portal-site-copy">
                  <h3>{surface.title}</h3>
                </div>
                <div class="card-actions">
                  <a class="button button-secondary" href={surface.href}>
                    打开入口
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="portal-snapshot-grid" aria-label="门户快照">
            {routeSignals.map((signal) => (
              <article class="snapshot-card">
                <p class="card-category">{signal.title}</p>
                <p class="snapshot-value">{signal.value}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="portal-section" aria-labelledby="portal-data-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Public data</p>
              <h2 id="portal-data-heading">数据入口导航</h2>
            </div>
          </div>

          <div class="portal-group-grid">
            {dataEntryLinks.map((entry) => (
              <article class="portal-site-card">
                <div class="portal-site-topline">
                  <p class="card-category">data</p>
                  <span class="status-badge">stable route</span>
                </div>

                <div class="portal-site-copy">
                  <h3>{entry.title}</h3>
                  <p>{entry.description}</p>
                </div>

                <p class="portal-site-domain">
                  <code>{entry.href}</code>
                </p>

                <div class="card-actions" aria-label={`${entry.title} 操作`}>
                  <a class="button button-primary" href={entry.href}>
                    打开入口
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="portal-section" aria-labelledby="portal-sites-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Portal sites</p>
              <h2 id="portal-sites-heading">站点入口</h2>
            </div>
          </div>

          <div class="portal-group-stack">
            {groupedEntries.map((group) => (
              <section class="portal-group-card" aria-labelledby={`portal-group-${group.id}`}>
                <div class="portal-group-head">
                  <div>
                    <p class="eyebrow">{group.id}</p>
                    <h3 id={`portal-group-${group.id}`}>{group.label}</h3>
                  </div>
                </div>

                <div class="portal-group-grid">
                  {group.entries.map((entry) => (
                    <PortalSiteCard entry={entry} />
                  ))}
                </div>
              </section>
            ))}
          </div>
        </section>
      </main>

      <IndexFooter />
    </div>
    <Analytics51LA />
  </body>
</html>
