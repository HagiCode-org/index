---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import IndexFooter from '@/components/IndexFooter.astro';
import PortalHero from '@/components/PortalHero.astro';
import PortalSiteCard from '@/components/PortalSiteCard.astro';
import { formatI18n, getLocaleNamespace, getString } from '@/i18n/runtime';
import { loadIndexCatalog } from '@/lib/load-index-catalog';
import { loadSitesCatalog } from '@/lib/load-sites-catalog';
import '@/styles/global.css';

const copy = getLocaleNamespace('hagindex');
const sitesCatalog = await loadSitesCatalog();
const indexCatalog = await loadIndexCatalog();
const groupedEntries = sitesCatalog.groups.map((group) => ({
  ...group,
  entries: sitesCatalog.entries.filter((entry) => entry.groupId === group.id),
}));
const featuredEntries = sitesCatalog.entries.filter(
  (entry) => entry.id === 'hagicode-main' || entry.id === 'hagicode-docs',
);
const portalGeneratedLabel = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
}).format(new Date(sitesCatalog.generatedAt));
const dataEntryLinks = [
  {
    id: 'steamAchievements',
    href: '/steam/achievements/',
  },
  {
    id: 'sitesJson',
    href: '/sites.json',
  },
  {
    id: 'indexCatalog',
    href: '/index-catalog.json',
  },
  {
    id: 'liveBroadcast',
    href: '/live-broadcast.json',
  },
  {
    id: 'steamAchievementsJson',
    href: '/steam/achievements.json',
  },
  {
    id: 'design',
    href: '/design.json',
  },
  {
    id: 'legalDocuments',
    href: '/legal-documents.json',
  },
  {
    id: 'desktopHistory',
    href: '/desktop/history/',
  },
  {
    id: 'serverHistory',
    href: '/server/history/',
  },
];
const operatingSurfaces = [
  {
    id: 'portal',
    href: '/',
  },
  {
    id: 'mirror',
    href: '/data/',
  },
  {
    id: 'history',
    href: '/desktop/history/',
  },
  {
    id: 'review',
    href: '/promoto',
  },
] as const;
const routeSignals = [
  {
    id: 'siteSnapshot',
    value: portalGeneratedLabel,
  },
  {
    id: 'publicIndexScale',
    value: String(indexCatalog.entries.length),
  },
  {
    id: 'stableRouteCount',
    value: String(dataEntryLinks.length),
  },
] as const;
const pageTitle = getString(copy, 'metadata.title');
const pageDescription = getString(copy, 'metadata.description');
const canonicalUrl = 'https://index.hagicode.com/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand-mark" href="/">H</a>
        <div>
          <p class="brand-name">{getString(copy, 'header.brandName')}</p>
          <p class="brand-subtitle">{getString(copy, 'header.brandSubtitle')}</p>
        </div>
        <nav class="site-header-actions" aria-label={getString(copy, 'header.navAria')}>
          <a class="header-link" href="/data/">{getString(copy, 'header.nav.dataPage')}</a>
          <a class="header-link" href="/sites.json" target="_blank" rel="noreferrer">{getString(copy, 'header.nav.sitesJson')}</a>
          <a class="header-link" href="/index-catalog.json" target="_blank" rel="noreferrer">{getString(copy, 'header.nav.catalogJson')}</a>
        </nav>
      </header>

      <main class="page-content portal-main">
        <PortalHero
          siteCount={sitesCatalog.entries.length}
          groupCount={sitesCatalog.groups.length}
          publicIndexCount={indexCatalog.entries.length}
          routeCount={dataEntryLinks.length}
          generatedAtLabel={portalGeneratedLabel}
          featuredEntries={featuredEntries}
          dataPagePath="/data/"
          sitesJsonPath="/sites.json"
          catalogPath="/index-catalog.json"
        />

        <section class="portal-section portal-surface-section" aria-labelledby="portal-surface-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">{getString(copy, 'sections.surface.eyebrow')}</p>
              <h2 id="portal-surface-heading">{getString(copy, 'sections.surface.title')}</h2>
            </div>
          </div>

          <div class="portal-surface-grid">
            {operatingSurfaces.map((surface) => (
              <article class="portal-surface-card">
                <div class="portal-site-topline">
                  <p class="card-category">{getString(copy, `surfaceCards.${surface.id}.label`)}</p>
                  <span class="status-badge">{getString(copy, `surfaceCards.${surface.id}.status`)}</span>
                </div>
                <div class="portal-site-copy">
                  <h3>{getString(copy, `surfaceCards.${surface.id}.title`)}</h3>
                </div>
                <div class="card-actions">
                  <a class="button button-secondary" href={surface.href}>
                    {getString(copy, `surfaceCards.${surface.id}.action`)}
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="portal-snapshot-grid" aria-label={getString(copy, 'sections.surface.snapshotAria')}>
            {routeSignals.map((signal) => (
              <article class="snapshot-card">
                <p class="card-category">{getString(copy, `routeSignals.${signal.id}`)}</p>
                <p class="snapshot-value">{signal.value}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="portal-section" aria-labelledby="portal-data-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">{getString(copy, 'sections.data.eyebrow')}</p>
              <h2 id="portal-data-heading">{getString(copy, 'sections.data.title')}</h2>
            </div>
          </div>

          <div class="portal-group-grid">
            {dataEntryLinks.map((entry) => (
              <article class="portal-site-card">
                <div class="portal-site-topline">
                  <p class="card-category">{getString(copy, 'dataCategory')}</p>
                  <span class="status-badge">{getString(copy, 'stableRouteBadge')}</span>
                </div>

                <div class="portal-site-copy">
                  <h3>{getString(copy, `dataEntries.${entry.id}.title`)}</h3>
                  <p>{getString(copy, `dataEntries.${entry.id}.description`)}</p>
                </div>

                <p class="portal-site-domain">
                  <code>{entry.href}</code>
                </p>

                <div
                  class="card-actions"
                  aria-label={formatI18n(getString(copy, 'siteCard.actionAriaTemplate'), {
                    title: getString(copy, `dataEntries.${entry.id}.title`),
                  })}
                >
                  <a class="button button-primary" href={entry.href}>
                    {getString(copy, 'surfaceCards.portal.action')}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="portal-section" aria-labelledby="portal-sites-heading">
          <div class="section-heading">
            <div>
              <p class="eyebrow">{getString(copy, 'sections.sites.eyebrow')}</p>
              <h2 id="portal-sites-heading">{getString(copy, 'sections.sites.title')}</h2>
            </div>
          </div>

          <div class="portal-group-stack">
            {groupedEntries.map((group) => (
              <section class="portal-group-card" aria-labelledby={`portal-group-${group.id}`}>
                <div class="portal-group-head">
                  <div>
                    <p class="eyebrow">{group.id}</p>
                    <h3 id={`portal-group-${group.id}`}>{group.label}</h3>
                  </div>
                </div>

                <div class="portal-group-grid">
                  {group.entries.map((entry) => (
                    <PortalSiteCard entry={entry} />
                  ))}
                </div>
              </section>
            ))}
          </div>
        </section>
      </main>

      <IndexFooter />
    </div>
    <Analytics51LA />
  </body>
</html>
