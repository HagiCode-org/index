---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import IndexFooter from '@/components/IndexFooter.astro';
import VersionHistoryPage from '@/components/VersionHistoryPage.astro';
import { loadPackageHistory } from '@/lib/load-package-history';
import '@/styles/global.css';

const page = await loadPackageHistory('server');
const pageTitle = `${page.title} | HagiCode Index`;
const pageDescription = 'HagiCode Server 的按版本分组历史页，仅展示 /server/index.json 中各版本可下载的 ZIP 包。';
const canonicalUrl = 'https://index.hagicode.com/server/history/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand-mark" href="/">H</a>
        <div>
          <p class="brand-name">HagiCode Index</p>
          <p class="brand-subtitle">Server grouped zip history</p>
        </div>
      </header>

      <main class="page-content">
        <VersionHistoryPage page={page} />
      </main>

      <IndexFooter />
    </div>
    <Analytics51LA />
  </body>
</html>
